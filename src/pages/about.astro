---
import Layout from '~/layouts/PageLayout.astro';
import Image from '~/components/common/Image.astro';
import { Icon } from 'astro-icon/components';
import { getHomePermalink } from '~/utils/permalinks';

const metadata = {
  title: 'About',
};
---

<Layout metadata={metadata}>
  <section class="relative md:-mt-[76px] not-prose">
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
      <div class="py-12 md:py-20">
        <div class="text-center pb-10 md:pb-16 max-w-5xl mx-auto">
          <Image
            class="mx-auto rounded-full w-24 h-24 object-cover mb-4"
            widths={[96, 192]}
            sizes="96px"
            loading="eager"
            width={96}
            height={96}
            src="~/assets/images/IMG_0007.jpg"
            alt="Geroen Joris Avatar"
          />
          <h1 class="text-5xl md:text-6xl font-bold leading-tighter tracking-tighter mb-4 font-heading dark:text-gray-200">
            Hi, I'm Geroen Joris
          </h1>
          <div class="max-w-3xl mx-auto">
            <p class="text-xl text-muted mb-6 dark:text-slate-300">
              Expert in AWS, DevSecOps, Software Architecture & Security
            </p>
            <div class="flex justify-center mt-4 space-x-4">
              <a href="https://github.com/gjoris" target="_blank" rel="noopener noreferrer" aria-label="Github">
                <Icon name="tabler:brand-github" class="w-6 h-6" />
              </a>
              <a href="https://linkedin.com/in/geroenjoris" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                <Icon name="tabler:brand-linkedin" class="w-6 h-6" />
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative not-prose">
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
      <div class="py-12 md:py-20">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-3xl font-bold leading-tighter tracking-tighter mb-4 font-heading dark:text-gray-200">
            My Story
          </h2>
          <p class="text-xl text-muted mb-6 dark:text-slate-300">
            Welcome to my blog! I'm Geroen Joris, a technology expert with a passion for building robust and secure software solutions in the cloud.
          </p>
          <p class="text-xl text-muted mb-6 dark:text-slate-300">
            My specializations include:
          </p>
          <ul class="list-disc pl-5 text-xl text-muted mb-6 dark:text-slate-300">
            <li>AWS Cloud Solutions</li>
            <li>DevSecOps & CI/CD Automation</li>
            <li>Software Architecture</li>
            <li>Application Security</li>
          </ul>
          <p class="text-xl text-muted mb-6 dark:text-slate-300">
            On this blog, I share my knowledge, experiences, and insights. You can also find me on <a href="https://github.com/gjoris" target="_blank" rel="noopener noreferrer">GitHub</a> and <a href="https://www.linkedin.com/in/geroenjoris" target="_blank" rel="noopener noreferrer">LinkedIn</a>.
          </p>
          <p class="text-sm text-muted mt-10 dark:text-slate-400">
            **Disclaimer:** This is my personal blog. The views expressed here are my own and do not necessarily reflect the views of my employer, Amazon Web Services (AWS).
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
