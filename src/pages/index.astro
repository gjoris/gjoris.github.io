---
import Layout from '~/layouts/PageLayout.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import { getCollection } from 'astro:content';
import { getPermalink } from '~/utils/permalinks';
import { getHomePermalink } from '~/utils/permalinks';
import Image from '~/components/common/Image.astro';
import { Icon } from 'astro-icon/components';

const posts = (await getCollection('post'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5); // Show latest 5 posts

const metadata = {
  title: 'Geroen Joris | Tech Blog',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <section class="relative md:-mt-[76px] not-prose">
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
      <div class="py-12 md:py-20">
        <div class="text-center pb-10 md:pb-16 max-w-5xl mx-auto">
          <Image
            class="mx-auto rounded-full w-24 h-24 object-cover mb-4"
            widths={[96, 192]}
            sizes="96px"
            loading="eager"
            width={96}
            height={96}
            src="~/assets/images/IMG_0007.jpg"
            alt="Geroen Joris Avatar"
          />
          <h1 class="text-5xl md:text-6xl font-bold leading-tighter tracking-tighter mb-4 font-heading dark:text-gray-200">
            Hi, I'm Geroen Joris
          </h1>
          <div class="max-w-3xl mx-auto">
            <p class="text-xl text-muted mb-6 dark:text-slate-300">
              Expert in AWS, DevSecOps, Software Architecture & Security
            </p>
            <div class="flex justify-center mt-4 space-x-4">
              <a href="https://github.com/gjoris" target="_blank" rel="noopener noreferrer" aria-label="Github">
                <Icon name="tabler:brand-github" class="w-6 h-6" />
              </a>
              <a href="https://linkedin.com/in/geroenjoris" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                <Icon name="tabler:brand-linkedin" class="w-6 h-6" />
              </a>
            </div>
            <div class="max-w-xs sm:max-w-md m-auto flex flex-nowrap flex-col sm:flex-row sm:justify-center gap-4 mt-6">
              <div class="flex w-full sm:w-auto">
                <a class="btn-primary w-full sm:mb-0" href={getPermalink('blog')}>View Blog</a>
              </div>
              <div class="flex w-full sm:w-auto">
                <a class="btn-secondary w-full sm:mb-0" href={getHomePermalink('about')}>About Me</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <BlogLatestPosts
    title="Latest Posts"
    information="Stay up-to-date with my latest insights on AWS, DevSecOps, software architecture, and security."
  />
</Layout>
